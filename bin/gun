#!/usr/bin/env bash
# gun — sandboxed code executor for construct
# Reads a JSON-RPC execute request from stdin, spawns deno with runner.ts,
# relays tool calls bidirectionally between the adapter and the sandbox.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNNER="${SCRIPT_DIR}/../runner/runner.ts"

# Resolve tools — use PATH first, fall back to nix store
jq_bin=$(command -v jq 2>/dev/null || echo "$(nix path-info nixpkgs#jq 2>/dev/null)/bin/jq")
deno_bin=$(command -v deno 2>/dev/null || echo "$(nix path-info nixpkgs#deno 2>/dev/null)/bin/deno")

# Read the execute request from stdin (single JSON line)
read -r request

# Extract fields
code=$(echo "$request" | "$jq_bin" -r '.params.code')
providers=$(echo "$request" | "$jq_bin" -c '.params.providers // []')
request_id=$(echo "$request" | "$jq_bin" -r '.id')

# Build initialize message for the runner
initialize=$("$jq_bin" -n -c \
  --arg code "$code" \
  --argjson providers "$providers" \
  '{jsonrpc: "2.0", method: "initialize", id: 1, params: {code: $code, providers: $providers}}')

# Spawn deno as a coprocess for bidirectional communication
coproc DENO { "$deno_bin" run --no-prompt "$RUNNER" 2>/dev/null; }

# Send initialize to deno
echo "$initialize" >&"${DENO[1]}"

# Relay loop: read from deno stdout, dispatch accordingly
while IFS= read -r line <&"${DENO[0]}"; do
  line=$(echo "$line" | tr -d '\r')
  [ -z "$line" ] && continue

  method=$(echo "$line" | "$jq_bin" -r '.method // empty')

  if [[ "$method" == "tool/call" ]]; then
    # Forward tool call to adapter (our stdout)
    echo "$line"
    # Read tool response from adapter (our stdin)
    IFS= read -r response
    # Forward response to deno
    echo "$response" >&"${DENO[1]}"

  elif [[ "$method" == "execute/result" ]]; then
    # Final result — wrap as JSON-RPC response for the adapter
    result_params=$(echo "$line" | "$jq_bin" -c '.params')
    "$jq_bin" -n -c \
      --argjson id "$request_id" \
      --argjson result "$result_params" \
      '{jsonrpc: "2.0", id: $id, result: $result}'
    break
  fi
done

# Clean up coprocess
exec {DENO[1]}>&-
wait "${DENO_PID}" 2>/dev/null || true
